rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['customerName', 'customerPhone', 'vehicleInfo', 'serviceDescription', 'createdAt'])
        && data.keys().size() == 5
        && data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() >= 7 && data.customerPhone.size() <= 20
        && data.vehicleInfo is string && data.vehicleInfo.size() > 0 && data.vehicleInfo.size() <= 200
        && data.serviceDescription is string && data.serviceDescription.size() > 0 && data.serviceDescription.size() <= 1000
        && data.createdAt is timestamp;
    }

    match /appointments/{appointmentId} {
      allow create: if isValidId(appointmentId) && isValidAppointment(request.resource.data);
      // Allow reading for availability checks. In a production app, we might restrict fields.
      allow read: if true;
    }
  }
}
